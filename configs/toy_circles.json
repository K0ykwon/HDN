{
  "experiment_name": "toy_circles_hdn",
  "model_name": "hdn_prototype",
  "seed": 19,
  "dataset": {
    "type": "toy",
    "name": "concentric_circles",
    "n_samples": 1024,
    "noise": 0.06,
    "train_split": 0.8
  },
  "model": {
    "hidden_dims": [32, 32],
    "activation": "tanh",
    "backbone": {
      "name": "flatten"
    },
    "structural": {
      "interval": 5,
      "birth": {
        "enabled": true,
        "loss_threshold": 0.15,
        "growth_amount": 4,
        "max_width": 128
      },
      "split": {
        "enabled": true,
        "heterogeneity_threshold": 0.2,
        "growth_amount": 2,
        "max_width": 128
      },
      "deepen": {
        "enabled": true,
        "plateau_gap": 0.02,
        "max_depth": 4
      },
      "prune": {
        "enabled": true,
        "usage_threshold": 0.015,
        "min_width": 8
      }
    }
  },
  "training": {
    "epochs": 200,
    "batch_size": 64,
    "learning_rate": 0.005,
    "weight_decay": 0.0001
  },
  "evaluation": {
    "busiest_node_ablation": true,
    "random_node_ablation": true,
    "corruptions": [
      {
        "type": "gaussian_noise",
        "std": 0.08
      }
    ]
  },
  "ablation": {
    "variants": ["no_balance", "no_split", "no_deepen", "no_prune"]
  },
  "logging": {
    "output_dir": "logs"
  }
}
