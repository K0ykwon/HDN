{
  "experiment_name": "mnist_hdn",
  "model_name": "hdn_prototype",
  "seed": 7,
  "dataset": {
    "type": "torchvision",
    "name": "mnist",
    "root": "./data",
    "train_split": 0.9,
    "use_test_as_valid": true,
    "normalize": {
      "mean": [0.1307],
      "std": [0.3081]
    }
  },
  "model": {
    "hidden_dims": [64, 64],
    "activation": "relu",
    "backbone": {
      "name": "flatten"
    },
    "structural": {
      "interval": 5,
      "birth": {
        "enabled": true,
        "loss_threshold": 0.2,
        "growth_amount": 8,
        "max_width": 256
      },
      "split": {
        "enabled": true,
        "heterogeneity_threshold": 0.25,
        "growth_amount": 4,
        "max_width": 256
      },
      "deepen": {
        "enabled": true,
        "plateau_gap": 0.02,
        "max_depth": 5
      },
      "prune": {
        "enabled": true,
        "usage_threshold": 0.015,
        "min_width": 8
      }
    }
  },
  "training": {
    "epochs": 20,
    "batch_size": 128,
    "learning_rate": 0.001,
    "weight_decay": 0.0001
  },
  "evaluation": {
    "busiest_node_ablation": true,
    "random_node_ablation": true,
    "corruptions": [
      {
        "type": "gaussian_noise",
        "std": 0.1
      },
      {
        "type": "feature_dropout",
        "probability": 0.15
      }
    ]
  },
  "ablation": {
    "variants": ["no_balance", "no_split", "no_deepen", "no_prune"]
  },
  "logging": {
    "output_dir": "logs"
  }
}
