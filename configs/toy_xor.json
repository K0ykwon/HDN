{
  "experiment_name": "toy_xor_baseline",
  "seed": 7,
  "dataset": {
    "type": "toy",
    "name": "xor",
    "n_samples": 512,
    "noise": 0.08,
    "train_split": 0.8
  },
  "model": {
    "hidden_dims": [16, 16],
    "activation": "relu",
    "backbone": {
      "name": "flatten"
    }
  },
  "training": {
    "epochs": 150,
    "batch_size": 64,
    "learning_rate": 0.01,
    "weight_decay": 0.0001
  },
  "logging": {
    "output_dir": "logs"
  }
}
