{
  "data": {
    "batch_size": 32,
    "num_classes": 2,
    "seq_len": 16,
    "special_token": 1,
    "task": "special_token_parity",
    "train_size": 512,
    "val_size": 256,
    "vocab_size": 32
  },
  "model": {
    "adaptive_depth": true,
    "attention_heads": 4,
    "dropout": 0.1,
    "embed_dim": 128,
    "event_dim": 128,
    "local_context_kernel": 3,
    "mixer_rank": 4,
    "mlp_hidden_dim": 256,
    "name": "twr",
    "slot_dim": 128,
    "slot_gate_bias": -2.8,
    "slot_gate_scale": 5.0,
    "slots": 16,
    "step_gate_bias": -2.4,
    "step_gate_scale": 3.5,
    "think_steps": 4,
    "use_slot_gate": true,
    "use_token_residual": false,
    "write_novelty_scale": 0.6,
    "write_temperature": 0.7,
    "write_topk": 2,
    "write_usage_decay": 0.9,
    "write_usage_penalty": 0.35,
    "write_variant": "soft_write"
  },
  "run": {
    "name": "twr_debug"
  },
  "train": {
    "balance_penalty_weight": 0.0002,
    "depth_penalty_weight": 0.0001,
    "epochs": 2,
    "grad_clip_norm": 1.0,
    "lr": 0.001,
    "seed": 7,
    "slot_penalty_weight": 0.0001,
    "warmup_fraction": 0.05,
    "weight_decay": 0.0,
    "write_penalty_weight": 0.0005
  }
}