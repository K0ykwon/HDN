{
  "data": {
    "batch_size": 8,
    "dataset_name": "pietrolesci/hyperpartisan_news_detection",
    "kind": "hf_text",
    "label_field": "hyperpartisan",
    "lowercase": true,
    "num_classes": 2,
    "seq_len": 512,
    "streaming": true,
    "text_field": "text",
    "train_size": 1200,
    "train_split": "train",
    "val_size": 400,
    "val_split": "validation",
    "vocab_size": 8192
  },
  "model": {
    "dropout": 0.1,
    "embed_dim": 128,
    "name": "mamba_placeholder",
    "num_layers": 4,
    "state_dim": 128
  },
  "run": {
    "name": "mamba_hyperpartisan_full"
  },
  "train": {
    "balance_penalty_weight": 0.0003,
    "depth_penalty_weight": 0.0,
    "epochs": 15,
    "grad_clip_norm": 1.0,
    "lr": 0.0003,
    "seed": 7,
    "slot_penalty_weight": 0.0,
    "warmup_fraction": 0.1,
    "weight_decay": 0.01,
    "write_penalty_weight": 0.001
  }
}