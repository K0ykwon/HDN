{
  "data": {
    "batch_size": 8,
    "dataset_name": "pietrolesci/hyperpartisan_news_detection",
    "kind": "hf_text",
    "label_field": "hyperpartisan",
    "local_files_only": true,
    "lowercase": true,
    "num_classes": 2,
    "seq_len": 512,
    "streaming": false,
    "text_field": "text",
    "train_size": 1200,
    "train_split": "train",
    "val_size": 400,
    "val_split": "validation",
    "vocab_size": 8192
  },
  "model": {
    "dropout": 0.1,
    "embed_dim": 48,
    "freeze_encoder": false,
    "local_context_kernel": 5,
    "mlp_hidden_dim": 128,
    "name": "twr",
    "num_readout_queries": 4,
    "slot_dim": 64,
    "stride": 2,
    "think_steps": 4,
    "window_size": 4
  },
  "run": {
    "name": "twr_backbone_hyperpartisan_lean"
  },
  "train": {
    "balance_penalty_weight": 0.0003,
    "depth_penalty_weight": 0.0,
    "epochs": 15,
    "grad_clip_norm": 1.0,
    "lr": 0.0003,
    "seed": 7,
    "slot_penalty_weight": 0.0,
    "warmup_fraction": 0.1,
    "weight_decay": 0.01,
    "write_penalty_weight": 0.001
  }
}